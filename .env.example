# Server port
PORT=4315

# Cornell AI Gateway (LiteLLM) — OpenAI-compatible endpoint
# Note the /v1 suffix for the OpenAI-compatible provider
GATEWAY_BASE_URL=https://api.ai.it.cornell.edu/v1
GATEWAY_API_KEY=''

# Default model id (as exposed by the gateway)
CHAT_MODEL=anthropic.claude-4.6-sonnet
CHAT_CONTEXT_LIMIT=200000

# Max agentic tool-calling rounds per turn
MAX_TOOL_ROUNDS=8

# Directory containing skill markdown files for the use_skill tool
SKILLS_DIR=./skills
