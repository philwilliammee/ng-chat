# Server port
PORT=4315

# Any OpenAI-compatible endpoint (OpenAI, Ollama, LiteLLM, Anthropic, etc.)
# Note the /v1 suffix required by most OpenAI-compatible providers
GATEWAY_BASE_URL=https://api.openai.com/v1
GATEWAY_API_KEY=''

# Model ID supported by your endpoint (e.g. gpt-4o-mini, claude-sonnet-4-6, llama3.2)
CHAT_MODEL=gpt-4o-mini

# Max context tokens passed to the model
CHAT_CONTEXT_LIMIT=200000

# Max agentic tool-calling rounds per turn
MAX_TOOL_ROUNDS=8

# Directory containing skill markdown files for the use_skill tool
SKILLS_DIR=./skills

# Extended thinking level: disabled | low | medium | high
# Server-side fallback when the client doesn't specify a level.
# Thinking only works with Claude 3.7+ via an Anthropic-compatible gateway.
THINKING_DEFAULT_LEVEL=disabled
