{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@server/*": ["./server/*"],
      "@ng-chat/server": ["./packages/chat-server/src/index.ts"],
      "@ng-chat/ui": ["./packages/chat-ui/src/public-api.ts"],
      "@ng-chat/storage": ["./packages/chat-storage/src/public-api.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "exclude": ["dist", "node_modules", "server"]
}
