{
  "name": "ng-chat",
  "version": "0.1.0",
  "description": "ng-chat — an open-source Angular + Hono agent chat base template built on the Vercel AI SDK UI Message Stream Protocol",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others \"npm run server:dev\" \"ng serve --proxy-config proxy.conf.json --port 4200\"",
    "server:dev": "tsx watch --env-file=.env server/index.ts",
    "build": "ng build --configuration production --output-path=dist/client",
    "start": "tsx --env-file=.env server/index.ts",
    "run:local": "npm run build && npm run start",
    "check": "tsc -p server/tsconfig.json --noEmit && ng build --configuration production"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@hono/node-server": "^1.14.0",
    "ai": "^6.0.0",
    "hono": "^4.7.0",
    "tsx": "^4.19.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@ai-sdk/angular": "^2.0.0",
    "@angular/animations": "^21.2.15",
    "@angular/build": "^21.2.13",
    "@angular/cdk": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/compiler-cli": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/forms": "^21.2.15",
    "@angular/material": "^21.2.13",
    "@angular/platform-browser": "^21.2.15",
    "@angular/platform-browser-dynamic": "^21.2.15",
    "@angular/router": "^21.2.15",
    "@types/node": "^24.12.4",
    "concurrently": "^9.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.0",
    "typescript": "~5.9.0",
    "zone.js": "^0.15.0"
  }
}
